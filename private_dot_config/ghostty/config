# The font families to use.
#
# You can generate the list of valid values using the CLI:
#
#     ghostty +list-fonts
#
# This configuration can be repeated multiple times to specify preferred

font-family = Operator Mono SSm
font-style = Book
font-size = 16

# font-family = MonoLisa Variable
# font-style = Medium
# font-size = 35


# Binds Shift+Enter to insert a newline character, preventing premature submission in applications that interpret Enter as a command.

keybind = global:ctrl+grave_accent=toggle_quick_terminal
keybind = shift+enter=text:\n
window-inherit-working-directory = true
quit-after-last-window-closed = true


# --- Quality of Life ---
# Hides the mouse pointer while you are typing
mouse-hide-while-typing = true

# scrollback-limit is in BYTES (not lines). Default is 10,000,000 (10 MB).
# Bumping to ~100 MB keeps a healthy buffer for reviewing long logs.
# Note: this is allocated per terminal surface as it fills.
scrollback-limit = 100000000

# Adds a slight margin so text doesn't hug the absolute edge of the window
window-padding-x = 10
window-padding-y = 10

# --- Keybindings & Modifiers ---
# Stops the Option key from printing Unicode characters (like ∫ or ƒ). 
# This is crucial so you can use Option+B and Option+F to jump words in bash/zsh/tmux.
# (You can also set this to `left` or `right` if you only want one key to act as Alt).
macos-option-as-alt = true
